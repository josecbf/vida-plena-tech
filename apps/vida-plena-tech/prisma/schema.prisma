// ╔══════════════════════════════════════════════════════════════════════╗
// ║  Vida Plena Tech — Schema canônico (demo local)                        ║
// ║                                                                        ║
// ║  Monólito modular. Um Core comum + módulos ativáveis (Pessoas, GCs,    ║
// ║  Eventos, e Ensino/EAD futuro). NENHUM módulo cria cadastro paralelo   ║
// ║  de pessoa: tudo aponta para Person do Core.                           ║
// ║                                                                        ║
// ║  Invariantes (ver docs/Técnico/Modelo de Dados Canonico.md):           ║
// ║   • Toda entidade operacional tem tenantId.                            ║
// ║   • Soft delete via archivedAt/deletedAt (histórico nunca some).       ║
// ║   • CPF é único por tenant (dedup) e sensível.                         ║
// ║   • Schema nasce multi-tenant (demo seeda 1 tenant).                   ║
// ║                                                                        ║
// ║  NOTA DE PRODUÇÃO: isolamento aqui é garantido na camada de aplicação  ║
// ║  (todo acesso passa por tenantId). Em produção, somar Postgres RLS.    ║
// ╚══════════════════════════════════════════════════════════════════════╝

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

/// Papel/cargo (RBAC). SEPARADO do status eclesiástico (ver complemento item 14).
enum RoleKey {
  MEMBER
  GC_LEADER
  SUPERVISOR
  COORDINATOR
  AREA_PASTOR
  SENIOR_PASTOR
  ADMIN
}

/// Status eclesiástico (relação com a igreja). NÃO confundir com cargo.
/// Mapeamento dos status do Prover: visitante→VISITOR, membro→MEMBER,
/// transferido→TRANSFERRED, excluído→ARCHIVED, inativo→INACTIVE.
/// (líder/supervisor/coordenador/pastor são CARGOS, viram RoleKey, não status.)
enum EclesiasticalStatus {
  VISITOR
  REGULAR_ATTENDER
  MEMBERSHIP_INTERESTED
  MEMBER
  INACTIVE
  AWAY
  TRANSFERRED
  ARCHIVED
}

enum Sex {
  MALE
  FEMALE
  UNDISCLOSED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  STABLE_UNION
  OTHER
}

enum ContactType {
  EMAIL
  PHONE
  WHATSAPP
}

enum RegistrationSource {
  PUBLIC_FORM
  GC_INVITE_LINK
  ADMIN_CREATED
  EVENT_PUBLIC
  PROVER_IMPORT
}

enum FamilyRelationship {
  SPOUSE
  FATHER
  MOTHER
  CHILD
  SIBLING
  GUARDIAN
  DEPENDENT
  OTHER
}

enum ScopeType {
  TENANT
  CAMPUS
  AREA
  SUPERVISION
  GC
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
  VISITOR
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED
}

enum EventVisibility {
  PUBLIC
  MEMBERS
  INTERNAL
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
}

enum TimelineEntryType {
  PERSON_CREATED
  STATUS_CHANGED
  GC_CHANGED
  FAMILY_LINKED
  EVENT_REGISTRATION
  EVENT_REGISTRATION_CANCELLED
  ATTENDANCE
  PASTORAL_NOTE
  CONSENT
  COURSE_COMPLETION // futuro (Ensino/EAD) — já reservado
  IMPORTED_FROM_PROVER // criação/atualização via importador Prover
}

enum Sensitivity {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum ConsentLegalBasis {
  CONSENT
  LEGITIMATE_INTEREST
  LEGAL_OBLIGATION
  CONTRACT
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  PENDING
  CREATED
  MATCHED
  SKIPPED
  FAILED
}

// Endurecimento do import (dry-run/apply estruturado).
enum ImportMode {
  DRY_RUN
  APPLY
}

enum ImportOperation {
  WOULD_CREATE
  WOULD_UPDATE
  WOULD_SKIP
  MATCHED
  FAILED
  // valores reais do APPLY
  CREATE
  UPDATE
  SKIP
}

enum MatchStrategy {
  EXTERNAL_MAPPING
  CPF
  NAME_CONTACT_BIRTHDATE
  COMPOSITE_KEY
  NONE
}

enum ImportSeverity {
  INFO
  WARNING
  CONFLICT
  ERROR
}

// ─────────────────────────────────────────────────────────────────────────
// CORE — tenancy, campus, identidade, módulos
// ─────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  tagline   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campuses             Campus[]
  memberships          TenantMembership[]
  people               Person[]
  households           Household[]
  growthGroups         GrowthGroup[]
  events               Event[]
  roleAssignments      RoleAssignment[]
  auditLogs            AuditLog[]
  domainEvents         DomainEvent[]
  outbox               DomainEventOutbox[]
  externalMappings     ExternalMapping[]
  importBatches        ImportBatch[]
  moduleSubscriptions  ModuleSubscription[]
}

model Campus {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  people       Person[]
  growthGroups GrowthGroup[]
  events       Event[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Identidade de login (pode ou não estar ligada a uma Person).
model User {
  id           String   @id @default(cuid())
  email        String
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships TenantMembership[]
  auditLogs   AuditLog[]

  @@unique([email])
}

/// Liga um User a um Tenant, opcionalmente a uma Person.
/// Pessoa pode existir SEM usuário; usuário pode se ligar a uma pessoa.
model TenantMembership {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  personId       String?   @unique
  status         String    @default("ACTIVE")
  invitedAt      DateTime?
  acceptedAt     DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  person          Person?          @relation(fields: [personId], references: [id])
  roleAssignments RoleAssignment[]

  @@unique([tenantId, userId])
  @@index([tenantId])
}

/// Papel atribuído a um membro, com escopo (deny-by-default na aplicação).
model RoleAssignment {
  id           String    @id @default(cuid())
  tenantId     String
  membershipId String
  role         RoleKey
  scopeType    ScopeType @default(TENANT)
  scopeId      String? // id do campus/área/supervisão/GC quando aplicável
  createdAt    DateTime  @default(now())

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  membership TenantMembership @relation(fields: [membershipId], references: [id])

  @@index([tenantId])
  @@index([membershipId])
}

/// Módulos ativáveis por tenant (Pessoas, GCs, Eventos, Ensino futuro).
model ModuleSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  moduleKey String // people | groups | events | teaching
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────
// PESSOAS
// ─────────────────────────────────────────────────────────────────────────

model Person {
  id           String   @id @default(cuid())
  tenantId     String
  campusId     String?

  fullName     String
  socialName   String? // apelido / nome social
  cpf          String? // OPCIONAL e SENSÍVEL; único por tenant (dedup)
  birthDate    DateTime?
  sex          Sex?
  maritalStatus MaritalStatus?

  status       EclesiasticalStatus @default(VISITOR)

  // Batismo
  isBaptized   Boolean   @default(false)
  baptismDate  DateTime?
  // Campos futuros pendentes: igreja, local, pastor/ministro (ver doc).

  // TD — Treinamento de Discípulos
  hasTD        Boolean   @default(false)
  tdDate       DateTime?

  // GC principal de cuidado pastoral (no máximo um)
  primaryGcId  String?

  operationalNotes String? // observações operacionais (não sensíveis)

  source       RegistrationSource @default(ADMIN_CREATED)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime? // soft delete / arquivamento

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  campus          Campus?           @relation(fields: [campusId], references: [id])
  primaryGc       GrowthGroup?      @relation("PrimaryGc", fields: [primaryGcId], references: [id])

  contacts        ContactMethod[]
  addresses       Address[]
  statusHistory   PersonStatusHistory[]
  gcHistory       GrowthGroupMembership[]
  pastoralNotes   PastoralNote[]
  timeline        TimelineEntry[]
  consents        ConsentRecord[]
  membership      TenantMembership?
  attendances     GrowthGroupAttendance[]
  eventRegs       EventRegistration[]
  leadershipMemberships LeadershipUnitMember[]

  // Vínculos familiares (dois lados da relação)
  householdLinksA HouseholdMember[] @relation("PersonA")
  ledGroups       GrowthGroup[]     @relation("GcLeader")
  assistedGroups  GrowthGroup[]     @relation("GcAssistant")

  @@unique([tenantId, cpf]) // CPF único por tenant; múltiplos NULL são permitidos no Postgres
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([primaryGcId])
}

model ContactMethod {
  id        String      @id @default(cuid())
  tenantId  String
  personId  String
  type      ContactType
  value     String
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

model Address {
  id         String  @id @default(cuid())
  tenantId   String
  personId   String
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  zipCode    String?
  createdAt  DateTime @default(now())

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

/// Histórico de status eclesiástico — preservado, nunca sobrescrito.
model PersonStatusHistory {
  id           String              @id @default(cuid())
  tenantId     String
  personId     String
  fromStatus   EclesiasticalStatus?
  toStatus     EclesiasticalStatus
  reason       String?
  actorUserId  String?
  createdAt    DateTime            @default(now())

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

/// Família/casa.
model Household {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  tenant  Tenant            @relation(fields: [tenantId], references: [id])
  members HouseholdMember[]

  @@index([tenantId])
}

/// Vínculo de uma pessoa a uma família, com tipo de relacionamento.
model HouseholdMember {
  id           String             @id @default(cuid())
  tenantId     String
  householdId  String
  personId     String
  relationship FamilyRelationship
  createdAt    DateTime           @default(now())

  household Household @relation(fields: [householdId], references: [id])
  person    Person    @relation("PersonA", fields: [personId], references: [id])

  @@unique([householdId, personId])
  @@index([tenantId])
  @@index([personId])
}

/// Observação pastoral SENSÍVEL — visível apenas a AREA_PASTOR e SENIOR_PASTOR
/// (complemento do dono, item 10). Toda leitura é auditada na aplicação.
model PastoralNote {
  id          String      @id @default(cuid())
  tenantId    String
  personId    String
  body        String
  sensitivity Sensitivity @default(CONFIDENTIAL)
  authorUserId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivedAt  DateTime?

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

/// Linha do tempo unificada da pessoa.
model TimelineEntry {
  id          String            @id @default(cuid())
  tenantId    String
  personId    String
  type        TimelineEntryType
  title       String
  description String?
  sensitivity Sensitivity       @default(INTERNAL)
  occurredAt  DateTime          @default(now())
  actorUserId String?

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

/// Consentimento versionado (LGPD).
model ConsentRecord {
  id            String            @id @default(cuid())
  tenantId      String
  personId      String
  purpose       String
  legalBasis    ConsentLegalBasis @default(CONSENT)
  consentVersion String           @default("v1")
  grantedAt     DateTime?
  revokedAt     DateTime?
  source        String?
  createdAt     DateTime          @default(now())

  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

// ─────────────────────────────────────────────────────────────────────────
// GRUPOS DE CRESCIMENTO
// ─────────────────────────────────────────────────────────────────────────

model GrowthGroup {
  id           String   @id @default(cuid())
  tenantId     String
  campusId     String?
  name         String

  // Cadeia de liderança LEGADA (compatibilidade da demo). Mantida; a evolução
  // é LeadershipUnit (abaixo). NOTA: assistantId é LEGADO e corresponde ao
  // conceito de "Líder 2" (NÃO "auxiliar") — ver regra de produto/nomenclatura.
  leaderId     String? // Líder 1 (legado)
  assistantId  String? // Líder 2 (legado) — antigo "auxiliar"
  supervisorId String? // membershipId do supervisor
  coordinatorId String? // membershipId do coordenador
  areaPastorId String? // membershipId do pastor de área

  // Unidades de liderança (novo modelo). Opcionais e ADITIVOS — os campos
  // legados acima (leaderId/assistantId/...) seguem como compatibilidade da demo.
  // Referenciam LeadershipUnit.id em nível de aplicação (sem FK p/ manter simples).
  leadershipUnitId   String?
  supervisionUnitId  String?
  coordinationUnitId String?
  areaPastorUnitId   String? // pode ficar nulo (export não traz pastor de área)

  weekday      Int? // 0=domingo .. 6=sábado
  time         String?
  location     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  campus      Campus?  @relation(fields: [campusId], references: [id])
  leader      Person?  @relation("GcLeader", fields: [leaderId], references: [id])
  assistant   Person?  @relation("GcAssistant", fields: [assistantId], references: [id])

  memberships GrowthGroupMembership[]
  meetings    GrowthGroupMeeting[]
  inviteLinks GrowthGroupInviteLink[]
  primaryFor  Person[]               @relation("PrimaryGc")

  @@index([tenantId])
  @@index([leaderId])
  @@index([supervisorId])
  @@index([leadershipUnitId])
}

// ─────────────────────────────────────────────────────────────────────────
// LEADERSHIP UNIT — liderança por pessoa, dupla/casal/casa ou equipe
// (ver docs/modules/leadership-unit-plan.md). Permissão continua POR PESSOA:
// acesso vem de ser LeadershipUnitMember ATIVO, nunca da família/sobrenome.
// ─────────────────────────────────────────────────────────────────────────

enum LeadershipUnitType {
  INDIVIDUAL
  DUAL
  COUPLE
  HOUSEHOLD
  TEAM
}

enum LeadershipMemberRole {
  PRIMARY
  SECONDARY
  SPOUSE
  ASSISTANT
  IN_TRAINING
  TEAM_MEMBER
}

model LeadershipUnit {
  id         String             @id @default(cuid())
  tenantId   String
  name       String
  type       LeadershipUnitType
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  archivedAt DateTime?

  members LeadershipUnitMember[]

  @@index([tenantId])
}

model LeadershipUnitMember {
  id               String               @id @default(cuid())
  tenantId         String
  leadershipUnitId String
  personId         String
  role             LeadershipMemberRole
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  archivedAt       DateTime?

  leadershipUnit LeadershipUnit @relation(fields: [leadershipUnitId], references: [id])
  person         Person         @relation(fields: [personId], references: [id])

  @@unique([leadershipUnitId, personId])
  @@index([tenantId])
  @@index([personId])
}

/// Origem de um vínculo de GC (de onde veio o registro).
enum GrowthGroupMembershipSource {
  PARTICIPANT // participante de GC (Prover grupos_participantes)
  VISITOR // visitante de GC (Prover grupos_visitantes) — NÃO é membro oficial
  MANUAL // criado dentro da plataforma
  IMPORTED // importação genérica (origem não distinguida)
}

/// Histórico de participação em GC — preservado mesmo após saída/transferência.
model GrowthGroupMembership {
  id        String    @id @default(cuid())
  tenantId  String
  gcId      String
  personId  String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime? // null = ativo; preenchido = histórico
  reason    String?
  source    GrowthGroupMembershipSource @default(MANUAL) // aditivo; default p/ linhas existentes

  gc     GrowthGroup @relation(fields: [gcId], references: [id])
  person Person      @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([gcId])
  @@index([personId])
}

/// Status real do encontro (preserva a semântica do Prover: agendado/realizado/cancelado).
enum GrowthGroupMeetingStatus {
  SCHEDULED // agendado
  HELD // realizado
  CANCELED // cancelado
  UNKNOWN // status de origem não reconhecido
}

model GrowthGroupMeeting {
  id        String   @id @default(cuid())
  tenantId  String
  gcId      String
  date      DateTime
  happened  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  actorUserId String?

  // Fase 4B.1 — campos aditivos (importação de encontros do Prover)
  status      GrowthGroupMeetingStatus @default(HELD) // happened mantido p/ compat
  sourceStatus String?                                // status cru do Prover (ex.: "realizado")
  title       String?                                 // tema do encontro
  endAt       DateTime?                               // data_fim
  metaJson    Json?                                   // oferta, num_criancas, quilos_doados…

  gc          GrowthGroup             @relation(fields: [gcId], references: [id])
  attendances GrowthGroupAttendance[]

  @@index([tenantId])
  @@index([gcId])
}

/// Origem de um registro de presença (de onde veio).
enum GrowthGroupAttendanceSource {
  PARTICIPANT // grupos_encontros_participantes (Prover)
  VISITOR // grupos_encontros_visitantes (Prover) — NÃO promove a membro
  MANUAL // registrado dentro da plataforma
}

model GrowthGroupAttendance {
  id         String           @id @default(cuid())
  tenantId   String
  meetingId  String
  personId   String?          // null para visitante avulso registrado pelo nome
  visitorName String?
  status     AttendanceStatus
  createdAt  DateTime         @default(now())

  // Fase 4B.2 — campos aditivos (importação de presenças do Prover)
  source     GrowthGroupAttendanceSource @default(MANUAL)
  sourceMark String?                                       // marca crua do Prover ("1"/"0")
  metaJson   Json?                                         // anotacao etc.

  meeting GrowthGroupMeeting @relation(fields: [meetingId], references: [id])
  person  Person?            @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([meetingId])
}

model GrowthGroupInviteLink {
  id        String   @id @default(cuid())
  tenantId  String
  gcId      String
  token     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  gc GrowthGroup @relation(fields: [gcId], references: [id])

  @@index([tenantId])
  @@index([gcId])
}

// ─────────────────────────────────────────────────────────────────────────
// EVENTOS (básico — sem pagamento/capacidade/lote nesta fase)
// ─────────────────────────────────────────────────────────────────────────

model Event {
  id          String          @id @default(cuid())
  tenantId    String
  campusId    String?
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  status      EventStatus     @default(DRAFT)
  visibility  EventVisibility @default(MEMBERS)
  createdByUserId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  archivedAt  DateTime?

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  campus        Campus?             @relation(fields: [campusId], references: [id])
  registrations EventRegistration[]

  @@index([tenantId])
}

model EventRegistration {
  id        String             @id @default(cuid())
  tenantId  String
  eventId   String
  personId  String
  status    RegistrationStatus @default(CONFIRMED)
  createdAt DateTime           @default(now())
  cancelledAt DateTime?

  event  Event  @relation(fields: [eventId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([eventId, personId])
  @@index([tenantId])
  @@index([personId])
}

// ─────────────────────────────────────────────────────────────────────────
// AUDITORIA + EVENTOS DE DOMÍNIO (forma canônica)
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  tenantId      String
  actorUserId   String?
  actorPersonId String?
  module        String?
  action        String // create | update | delete | status_changed | read_sensitive ...
  entityType    String
  entityId      String?
  sensitivity   Sensitivity @default(INTERNAL)
  beforeJson    Json?
  afterJson     Json?
  reason        String?
  ip            String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([createdAt])
}

/// Evento de domínio (registro canônico). Gravado na MESMA transação da escrita.
model DomainEvent {
  id            String      @id @default(cuid())
  tenantId      String
  eventType     String // ex: person.created
  aggregateType String // ex: Person
  aggregateId   String
  actorUserId   String?
  payloadJson   Json
  schemaVersion Int         @default(1)
  sensitivity   Sensitivity @default(INTERNAL)
  createdAt     DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventType])
}

/// Outbox transacional. Um publicador (futuro) lê PENDING e publica.
model DomainEventOutbox {
  id            String       @id @default(cuid())
  tenantId      String
  eventType     String
  aggregateType String
  aggregateId   String
  payloadJson   Json
  schemaVersion Int          @default(1)
  sensitivity   Sensitivity  @default(INTERNAL)
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  nextRetryAt   DateTime?
  createdAt     DateTime     @default(now())
  publishedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// INTEGRAÇÃO PROVER (estrutura apenas — somente leitura no futuro)
// ─────────────────────────────────────────────────────────────────────────

/// Mapeia ids externos (Prover) → entidades internas. Garante idempotência.
///
/// POLIMÓRFICO de propósito (sem FK direta): o importador Prover precisa mapear
/// Person, GrowthGroup, Event, GrowthGroupMeeting, EventRegistration, Course etc.
/// `internalType` + `internalId` identificam a entidade; a integridade é
/// garantida pela aplicação (não por FK), pois o alvo varia por tipo.
model ExternalMapping {
  id             String   @id @default(cuid())
  tenantId       String
  system         String   @default("PROVER")
  externalType   String // ex: person, growth_group, event
  externalId     String
  internalType   String // ex: Person, GrowthGroup, Event, GrowthGroupMeeting, EventRegistration, Course
  internalId     String
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, system, externalType, externalId])
  @@index([tenantId])
  @@index([tenantId, internalType, internalId])
}

model ImportBatch {
  id        String       @id @default(cuid())
  tenantId  String
  mode      ImportMode   @default(DRY_RUN)
  system    String       @default("PROVER") // = source
  status    ImportStatus @default(PENDING)
  fileName  String? // = sourceFileName
  sourceFileHash String?
  // Contadores estruturados (total/created/matched/skipped/failed reaproveitados)
  total     Int          @default(0) // totalItems
  created   Int          @default(0) // createdItems
  matched   Int          @default(0) // matchedItems
  skipped   Int          @default(0) // skippedItems
  failed    Int          @default(0) // failedItems
  warnings  Int          @default(0) // warningItems
  conflicts Int          @default(0) // conflictItems
  createdAt DateTime     @default(now()) // = startedAt
  finishedAt DateTime?

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  items  ImportBatchItem[]

  @@index([tenantId])
}

model ImportBatchItem {
  id           String           @id @default(cuid())
  tenantId     String
  batchId      String
  externalType String? // ex.: "person"
  externalId   String?
  // Campos estruturados (message vira resumo legível, não fonte da verdade)
  operation     ImportOperation?
  matchStrategy MatchStrategy?
  severity      ImportSeverity?
  targetType    String? // ex.: "Person"
  targetId      String? // id interno quando há match (dry-run não cria)
  normalizedJson Json?
  warningsJson   Json?
  errorsJson     Json?
  rawJson      Json
  status       ImportItemStatus @default(PENDING)
  message      String?
  createdAt    DateTime         @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id])

  @@index([tenantId])
  @@index([batchId])
}

// ── FASE 3B.2 — decisão humana de conflitos de vínculo de GC (rascunho) ──
enum GcMembershipConflictType {
  MULTIPLE_ACTIVE_GCS
  DUPLICATE_MEMBERSHIP_CONFLICT
  ACTIVE_MEMBERSHIP_IN_INACTIVE_GC
  PERSON_MAPPING_NOT_FOUND
}

enum GcMembershipConflictDecision {
  KEEP_THIS_GC_ACTIVE
  CLOSE_THIS_MEMBERSHIP
  IGNORE_DUPLICATE
  CONSOLIDATE_HISTORY
  MAP_ALIAS_TO_PERSON
  REVIEW_LATER
}

enum GcMembershipConflictResolutionStatus {
  DRAFT
  READY_TO_APPLY
  APPLIED
  CANCELLED
}

/// Decisão humana (RASCUNHO/auditável) para um conflito de vínculo de GC.
/// NÃO aplica efeito real — a aplicação fica para a Fase 3B.3.
model GcMembershipConflictResolution {
  id          String                   @id @default(cuid())
  tenantId    String
  type        GcMembershipConflictType
  conflictKey String

  personId         String?
  growthGroupId    String?
  proverPersonUuid String?

  decision GcMembershipConflictDecision
  status   GcMembershipConflictResolutionStatus @default(DRAFT)

  note        String?
  payloadJson Json?

  decidedByUserId String?
  decidedAt       DateTime?

  // Fase 3B.3 — aplicação controlada (aditivo)
  appliedAt       DateTime?
  appliedByUserId String?
  applyBatchId    String?
  applyResultJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, conflictKey])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([personId])
  @@index([growthGroupId])
}
