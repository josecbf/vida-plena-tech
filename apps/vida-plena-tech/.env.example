# ───────────────────────────────────────────────────────────────
# Vida Plena Tech — variáveis de ambiente (DEMO)
# Copie para .env.local e ajuste. NUNCA commite .env.local.
# ───────────────────────────────────────────────────────────────

# Banco (Docker Compose sobe um Postgres em localhost:5433)
DATABASE_URL="postgresql://vidaplena:vidaplena@localhost:5433/vidaplena?schema=public"

# Segredo da sessão de DEMO (assinatura do cookie JWT). Troque por um valor aleatório.
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-este-segredo-em-producao-0000000000000000"

# ───────────────────────────────────────────────────────────────
# Integração Prover (FUTURO — somente leitura/importação)
# Nesta fase NADA é chamado. A chave fica aqui, nunca no código.
# Prover virá como ZIP de JSONs; só preparamos o contrato de importação.
# ───────────────────────────────────────────────────────────────
PROVER_API_BASE_URL=""
PROVER_API_KEY=""
